{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openphone.dev/schemas/trajectory-event.schema.json",
  "title": "OpenPhone Trajectory Event",
  "type": "object",
  "required": ["schema", "index", "timestamp_ms", "event", "payload"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "openphone.trajectory_event.v1"
    },
    "index": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp_ms": {
      "type": "integer"
    },
    "event": {
      "enum": [
        "task_started",
        "tool_call",
        "tool_result",
        "agent_result"
      ]
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
