{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openphone.example/contracts/ota-feed.schema.json",
  "title": "OpenPhone OTA Feed",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "channel",
    "device",
    "updates"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "channel": {
      "type": "string",
      "minLength": 1
    },
    "device": {
      "type": "string",
      "minLength": 1
    },
    "updates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "version",
          "filename",
          "url",
          "size",
          "sha256",
          "requires_wipe",
          "release_notes_url"
        ],
        "additionalProperties": false,
        "properties": {
          "version": {
            "type": "string",
            "minLength": 1
          },
          "filename": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "size": {
            "type": "integer",
            "minimum": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "requires_wipe": {
            "type": "boolean"
          },
          "release_notes_url": {
            "type": "string"
          }
        }
      }
    }
  }
}
