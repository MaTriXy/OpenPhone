 package com.android.settings.openphone;

 import android.app.settings.SettingsEnums;
+import android.os.Bundle;
+import android.provider.Settings;

+import androidx.preference.Preference;
+import androidx.preference.SwitchPreferenceCompat;
+
 import com.android.settings.R;
 import com.android.settings.dashboard.DashboardFragment;
 import com.android.settings.search.BaseSearchIndexProvider;
 import com.android.settingslib.search.SearchIndexable;

 @SearchIndexable
-public class OpenPhoneTaskGrantSettings extends DashboardFragment {
+public class OpenPhoneTaskGrantSettings extends DashboardFragment
+        implements Preference.OnPreferenceChangeListener {
     private static final String TAG = "OpenPhoneTaskGrants";
+    private static final String KEY_INPUT = "openphone_grant_input";
+    private static final String KEY_SCREENSHOT = "openphone_grant_screenshot";
+    private static final String KEY_CLIPBOARD = "openphone_grant_clipboard";
+    private static final String KEY_SHARE = "openphone_grant_share";
+    private static final String KEY_NETWORK = "openphone_grant_network";
+
+    private static final String SECURE_INPUT = "openphone_task_grant_input";
+    private static final String SECURE_SCREENSHOT = "openphone_task_grant_screenshot";
+    private static final String SECURE_CLIPBOARD = "openphone_task_grant_clipboard";
+    private static final String SECURE_SHARE = "openphone_task_grant_share";
+    private static final String SECURE_NETWORK = "openphone_task_grant_network";
+
+    @Override
+    public void onCreate(Bundle icicle) {
+        super.onCreate(icicle);
+        bindGrant(KEY_INPUT, SECURE_INPUT, true);
+        bindGrant(KEY_SCREENSHOT, SECURE_SCREENSHOT, true);
+        bindGrant(KEY_CLIPBOARD, SECURE_CLIPBOARD, false);
+        bindGrant(KEY_SHARE, SECURE_SHARE, false);
+        bindGrant(KEY_NETWORK, SECURE_NETWORK, true);
+    }

     @Override
     public int getMetricsCategory() {
         return SettingsEnums.DASHBOARD_SUMMARY;
     }

     @Override
     protected String getLogTag() {
         return TAG;
     }

     @Override
     protected int getPreferenceScreenResId() {
         return R.xml.openphone_task_grants;
     }

+    @Override
+    public boolean onPreferenceChange(Preference preference, Object newValue) {
+        if (!(newValue instanceof Boolean)) {
+            return false;
+        }
+        final String secureKey = secureKeyForPreference(preference.getKey());
+        if (secureKey == null) {
+            return false;
+        }
+        Settings.Secure.putInt(getContentResolver(), secureKey, (Boolean) newValue ? 1 : 0);
+        return true;
+    }
+
+    private void bindGrant(String key, String secureKey, boolean defaultValue) {
+        final SwitchPreferenceCompat preference = findPreference(key);
+        if (preference == null) {
+            return;
+        }
+        preference.setChecked(Settings.Secure.getInt(getContentResolver(), secureKey,
+                defaultValue ? 1 : 0) == 1);
+        preference.setOnPreferenceChangeListener(this);
+    }
+
+    private static String secureKeyForPreference(String preferenceKey) {
+        if (KEY_INPUT.equals(preferenceKey)) {
+            return SECURE_INPUT;
+        }
+        if (KEY_SCREENSHOT.equals(preferenceKey)) {
+            return SECURE_SCREENSHOT;
+        }
+        if (KEY_CLIPBOARD.equals(preferenceKey)) {
+            return SECURE_CLIPBOARD;
+        }
+        if (KEY_SHARE.equals(preferenceKey)) {
+            return SECURE_SHARE;
+        }
+        if (KEY_NETWORK.equals(preferenceKey)) {
+            return SECURE_NETWORK;
+        }
+        return null;
+    }
+
     public static final BaseSearchIndexProvider SEARCH_INDEX_DATA_PROVIDER =
             new BaseSearchIndexProvider(R.xml.openphone_task_grants);
 }
