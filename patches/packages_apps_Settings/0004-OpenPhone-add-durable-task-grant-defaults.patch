From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OpenPhone <openphone@example.invalid>
Date: Mon, 1 Jun 2026 19:45:00 +0300
Subject: [PATCH] OpenPhone: add durable task grant defaults

Convert the Settings-hosted OpenPhone task grants page from a static explainer
into a small durable editor. Defaults are stored in Settings.Secure so trusted
OpenPhone components can share the same task posture before each assistant run.
---

diff --git a/res/xml/openphone_task_grants.xml b/res/xml/openphone_task_grants.xml
index 8bdb0e1fbcd..a00e14262b1 100644
--- a/res/xml/openphone_task_grants.xml
+++ b/res/xml/openphone_task_grants.xml
@@ -12,29 +12,35 @@
         android:summary="@string/openphone_task_grants_intro_summary"
         android:selectable="false"/>

-    <Preference
+    <SwitchPreferenceCompat
         android:key="openphone_grant_input"
         android:title="@string/openphone_grant_input_title"
         android:summary="@string/openphone_grant_input_summary"
-        android:selectable="false"/>
+        android:defaultValue="true"/>

-    <Preference
+    <SwitchPreferenceCompat
         android:key="openphone_grant_screenshot"
         android:title="@string/openphone_grant_screenshot_title"
         android:summary="@string/openphone_grant_screenshot_summary"
-        android:selectable="false"/>
+        android:defaultValue="true"/>

-    <Preference
+    <SwitchPreferenceCompat
         android:key="openphone_grant_clipboard"
         android:title="@string/openphone_grant_clipboard_title"
         android:summary="@string/openphone_grant_clipboard_summary"
-        android:selectable="false"/>
+        android:defaultValue="false"/>

-    <Preference
+    <SwitchPreferenceCompat
         android:key="openphone_grant_share"
         android:title="@string/openphone_grant_share_title"
         android:summary="@string/openphone_grant_share_summary"
-        android:selectable="false"/>
+        android:defaultValue="false"/>
+
+    <SwitchPreferenceCompat
+        android:key="openphone_grant_network"
+        android:title="@string/openphone_grant_network_title"
+        android:summary="@string/openphone_grant_network_summary"
+        android:defaultValue="true"/>

     <Preference
         android:key="openphone_assistant_grants"
diff --git a/res/values/strings.xml b/res/values/strings.xml
index 6c4c3696cf3..8e970931c86 100644
--- a/res/values/strings.xml
+++ b/res/values/strings.xml
@@ -3663,6 +3663,10 @@
     <string name="openphone_grant_share_title" translatable="false">Sharing and links</string>
     <!-- OpenPhone sharing grant summary. -->
     <string name="openphone_grant_share_summary" translatable="false">Allows share-sheet and web-link tools; risky sends still require confirmation.</string>
+    <!-- OpenPhone network grant title. -->
+    <string name="openphone_grant_network_title" translatable="false">Web links</string>
+    <!-- OpenPhone network grant summary. -->
+    <string name="openphone_grant_network_summary" translatable="false">Allows the assistant to open web links while an active task is running.</string>
     <!-- OpenPhone audit screen title. -->
     <string name="openphone_audit_screen_title" translatable="false">Audit evidence</string>
     <!-- OpenPhone audit recent events title. -->
diff --git a/src/com/android/settings/openphone/OpenPhoneTaskGrantSettings.java b/src/com/android/settings/openphone/OpenPhoneTaskGrantSettings.java
index 36d35aa3ca8..3f9776c122d 100644
--- a/src/com/android/settings/openphone/OpenPhoneTaskGrantSettings.java
+++ b/src/com/android/settings/openphone/OpenPhoneTaskGrantSettings.java
@@ -1,38 +1,107 @@
