From 2cb9cf6037af8f6a1f7ed7b06a7d0c8c2f47d2e4 Mon Sep 17 00:00:00 2001
From: OpenPhone <dev@openphone.local>
Date: Mon, 1 Jun 2026 21:45:00 +0300
Subject: [PATCH] OpenPhone: add mediated open URL action

Route model-requested web-link opening through the framework action
executor so network launches get the same task, policy, and audit
handling as other OpenPhone actions.

Change-Id: I6d8d34ff8d0b84cb0ee5cb63d415ff0b90c22451
---
 .../openphone/OpenPhoneAgentManagerService.java | 61 ++++++++++++++++--
 1 file changed, 54 insertions(+), 7 deletions(-)

diff --git a/services/core/java/com/android/server/openphone/OpenPhoneAgentManagerService.java b/services/core/java/com/android/server/openphone/OpenPhoneAgentManagerService.java
index 7b5fee3a8645..973d9c97d7ff 100644
--- a/services/core/java/com/android/server/openphone/OpenPhoneAgentManagerService.java
+++ b/services/core/java/com/android/server/openphone/OpenPhoneAgentManagerService.java
@@ -22,6 +22,7 @@ import android.content.ClipboardManager;
 import android.content.Context;
 import android.content.ComponentName;
 import android.content.Intent;
+import android.net.Uri;
 import android.graphics.Bitmap;
 import android.hardware.input.InputManager;
 import android.openphone.IOpenPhoneAgentService;
@@ -377,6 +378,9 @@ public final class OpenPhoneAgentManagerService extends SystemService {
             if ("open_app".equals(type)) {
                 return executeOpenApp(taskId, actionRequestJson, request, capability);
             }
+            if ("open_url".equals(type)) {
+                return executeOpenUrl(taskId, actionRequestJson, request, capability);
+            }
             if ("back".equals(type) || "home".equals(type) || "recents".equals(type)) {
                 return executeNavigationKey(taskId, actionRequestJson, type, capability);
             }
@@ -439,6 +443,46 @@ public final class OpenPhoneAgentManagerService extends SystemService {
                     capability, packageName);
         }

+        private String executeOpenUrl(String taskId, String actionRequestJson, JSONObject request,
+                String capability) {
+            final String url = request.optString("url", "").trim();
+            if (url.isEmpty()) {
+                recordAudit("action_rejected", taskId, capability, "deny",
+                        actionRequestJson, "missing_url");
+                return actionResultJson("action.denied.missing_url", taskId, actionRequestJson,
+                        capability, "missing_url");
+            }
+
+            final Uri uri = Uri.parse(url);
+            final String scheme = uri == null ? null : uri.getScheme();
+            if (!"https".equalsIgnoreCase(scheme) && !"http".equalsIgnoreCase(scheme)) {
+                recordAudit("action_rejected", taskId, capability, "deny",
+                        actionRequestJson, "unsupported_url_scheme");
+                return actionResultJson("action.denied.unsupported_url_scheme", taskId,
+                        actionRequestJson, capability, "unsupported_url_scheme");
+            }
+
+            final Intent intent = new Intent(Intent.ACTION_VIEW, uri);
+            intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK);
+            intent.setPackage("org.lineageos.jelly");
+            final long token = Binder.clearCallingIdentity();
+            try {
+                mContext.startActivityAsUser(intent, foregroundUser());
+            } catch (RuntimeException e) {
+                recordAudit("action_rejected", taskId, capability, "deny",
+                        actionRequestJson, "open_url_failed:" + e.getClass().getSimpleName());
+                return actionResultJson("action.denied.open_url_failed", taskId,
+                        actionRequestJson, capability, e.getClass().getSimpleName());
+            } finally {
+                Binder.restoreCallingIdentity(token);
+            }
+
+            recordAudit("action_executed", taskId, capability, "allow_task_scoped",
+                    actionRequestJson, url);
+            return actionResultJson("action.executed", taskId, actionRequestJson, capability,
+                    url);
+        }
+
         private String executeNavigationKey(String taskId, String actionRequestJson, String type,
                 String capability) {
             final int keyCode;
@@ -889,6 +931,9 @@ public final class OpenPhoneAgentManagerService extends SystemService {
             if ("open_app".equals(type) || "launch_intent".equals(type)) {
                 return "apps.launch";
             }
+            if ("open_url".equals(type)) {
+                return "network.use";
+            }
             if ("back".equals(type) || "home".equals(type) || "recents".equals(type)
                     || "tap".equals(type) || "long_press".equals(type)
                     || "scroll".equals(type) || "type_text".equals(type)) {
@@ -910,13 +955,20 @@ public final class OpenPhoneAgentManagerService extends SystemService {
             if ("back".equals(type) || "home".equals(type) || "recents".equals(type)) {
                 return "allow_task_scoped";
             }
-            if ("input.perform".equals(capabilityId) && taskHasGrant(taskId, capabilityId)) {
+            if (taskHasGrant(taskId, capabilityId) && !requiresExplicitConfirmation(capabilityId)) {
                 return "allow_task_scoped";
             }
             return decisionForCapability(capabilityId);
         }

+        private static boolean requiresExplicitConfirmation(String capabilityId) {
+            return "messages.send".equals(capabilityId)
+                    || "calls.place".equals(capabilityId)
+                    || "account.access".equals(capabilityId)
+                    || "share.content".equals(capabilityId);
+        }
+
         private static boolean isConfirmationDecision(String decision) {
             return "confirmation_required".equals(decision)
                     || "explicit_confirmation_required".equals(decision);
         }
@@ -957,13 +1009,11 @@ public final class OpenPhoneAgentManagerService extends SystemService {
                     || "settings.write".equals(capabilityId)
                     || "notifications.act".equals(capabilityId)
                     || "clipboard.read".equals(capabilityId)
-                    || "clipboard.write".equals(capabilityId)) {
+                    || "clipboard.write".equals(capabilityId)
+                    || "network.use".equals(capabilityId)) {
                 return "confirmation_required";
             }
-            if ("messages.send".equals(capabilityId)
-                    || "calls.place".equals(capabilityId)
-                    || "account.access".equals(capabilityId)
-                    || "share.content".equals(capabilityId)) {
+            if (requiresExplicitConfirmation(capabilityId)) {
                 return "explicit_confirmation_required";
             }
             return "deny";
--
2.50.1
