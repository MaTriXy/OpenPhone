+ *
+ * SPDX-License-Identifier: PolyForm-Noncommercial-1.0.0
+ *
+ * Commercial use requires a separate written license.
+ */
+
+package android.openphone;
+
+import android.annotation.NonNull;
+import android.annotation.SystemService;
+import android.content.Context;
+import android.os.RemoteException;
+
+/**
+ * Client API for the OS-owned OpenPhone context index service.
+ *
+ * @hide
+ */
+@SystemService(Context.OPENPHONE_CONTEXT_SERVICE)
+public final class OpenPhoneContextManager {
+    private final IOpenPhoneContextIndexService mService;
+
+    /** @hide */
+    public OpenPhoneContextManager(@NonNull IOpenPhoneContextIndexService service) {
+        mService = service;
+    }
+
+    /** @hide */
+    @NonNull
+    public String getServiceStatus() {
+        try {
+            return mService.getServiceStatus();
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String insertEvent(@NonNull String eventJson) {
+        try {
+            return mService.insertEvent(eventJson);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String insertEvents(@NonNull String eventsJsonArray) {
+        try {
+            return mService.insertEvents(eventsJsonArray);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String queryEvents(@NonNull String requestJson) {
+        try {
+            return mService.queryEvents(requestJson);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+
+    /** @hide */
+    @NonNull
+    public String tombstoneEvent(long eventId) {
+        try {
+            return mService.tombstoneEvent(eventId);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+    }
+}
