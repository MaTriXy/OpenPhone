diff --git a/services/core/java/com/android/server/openphone/OpenPhoneContextIndexService.java b/services/core/java/com/android/server/openphone/OpenPhoneContextIndexService.java
new file mode 100644
index 000000000000..fee64289f2f2
--- /dev/null
+++ b/services/core/java/com/android/server/openphone/OpenPhoneContextIndexService.java
@@ -0,0 +1,421 @@
+/*
+ * Copyright 2026 OpenPhone contributors.
+ *
+ * SPDX-License-Identifier: PolyForm-Noncommercial-1.0.0
+ *
+ * Commercial use requires a separate written license.
+ */
+
+package com.android.server.openphone;
+
+import android.content.Context;
+import android.database.Cursor;
+import android.database.sqlite.SQLiteDatabase;
+import android.openphone.IOpenPhoneContextIndexService;
+import android.os.Binder;
+import android.os.Environment;
+import android.util.Slog;
+
+import com.android.server.SystemService;
+
+import org.json.JSONArray;
+import org.json.JSONException;
+import org.json.JSONObject;
+
+import java.io.File;
+import java.util.ArrayList;
+import java.util.List;
+
+/**
+ * OS-owned durable context index. Owns the canonical context_event store under
+ * /data/system/openphone/ so user context survives assistant reinstalls and can
+ * later serve more than one client surface.
+ */
+public final class OpenPhoneContextIndexService extends SystemService {
+    private static final String TAG = "OpenPhoneContextIndex";
+    private static final String PERMISSION_USE_CONTEXT_INDEX =
+            "org.openphone.permission.USE_CONTEXT_INDEX";
+    private static final String OPENPHONE_SYSTEM_DIR = "openphone";
+    private static final String DB_FILE = "context_index.db";
+    private static final int SCHEMA_VERSION = 1;
+    private static final int MAX_LIMIT = 100;
+
+    private final BinderService mBinderService;
+
+    public OpenPhoneContextIndexService(Context context) {
+        super(context);
+        mBinderService = new BinderService(context);
+    }
+
+    @Override
+    public void onStart() {
+        publishBinderService(Context.OPENPHONE_CONTEXT_SERVICE, mBinderService);
+        Slog.i(TAG, "OpenPhone context index service published");
+    }
+
+    private static final class BinderService extends IOpenPhoneContextIndexService.Stub {
+        private final Context mContext;
+        private final Object mDbLock = new Object();
+        private SQLiteDatabase mDb;
+
+        BinderService(Context context) {
+            mContext = context;
+        }
+
+        @Override
+        public String getServiceStatus() {
+            enforceUseContextIndex();
+            long count = -1L;
+            synchronized (mDbLock) {
+                try {
+                    final SQLiteDatabase db = openLocked();
+                    try (Cursor cursor = db.rawQuery(
+                            "SELECT COUNT(*) FROM context_event WHERE deleted_at IS NULL",
+                            null)) {
+                        if (cursor.moveToFirst()) {
+                            count = cursor.getLong(0);
+                        }
+                    }
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "status query failed", e);
+                }
+            }
+            final JSONObject json = new JSONObject();
+            try {
+                json.put("state", "ready");
+                json.put("service", Context.OPENPHONE_CONTEXT_SERVICE);
+                json.put("schema_version", SCHEMA_VERSION);
+                json.put("event_count", count);
+                json.put("source", "system_server.openphone_context");
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+
+        @Override
+        public String insertEvent(String eventJson) {
+            enforceUseContextIndex();
+            final JSONObject event;
+            try {
+                event = new JSONObject(eventJson == null || eventJson.isEmpty()
+                        ? "{}" : eventJson);
+            } catch (JSONException e) {
+                return errorJson("invalid_event_json");
+            }
+            final String sourceType = event.optString("source_type", "").trim();
+            if (sourceType.isEmpty()) {
+                return errorJson("missing_source_type");
+            }
+            final long id;
+            synchronized (mDbLock) {
+                try {
+                    id = insertEventLocked(openLocked(), event);
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "insert failed", e);
+                    return errorJson("insert_failed");
+                }
+            }
+            final JSONObject json = new JSONObject();
+            try {
+                json.put("id", id);
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+
+        @Override
+        public String insertEvents(String eventsJsonArray) {
+            enforceUseContextIndex();
+            final JSONArray events;
+            try {
+                events = new JSONArray(eventsJsonArray == null || eventsJsonArray.isEmpty()
+                        ? "[]" : eventsJsonArray);
+            } catch (JSONException e) {
+                return errorJson("invalid_events_json");
+            }
+            int inserted = 0;
+            int skipped = 0;
+            synchronized (mDbLock) {
+                final SQLiteDatabase db;
+                try {
+                    db = openLocked();
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "batch insert open failed", e);
+                    return errorJson("insert_failed");
+                }
+                db.beginTransaction();
+                try {
+                    for (int i = 0; i < events.length(); i++) {
+                        final JSONObject event = events.optJSONObject(i);
+                        if (event == null
+                                || event.optString("source_type", "").trim().isEmpty()) {
+                            skipped++;
+                            continue;
+                        }
+                        if (insertEventLocked(db, event) > 0) {
+                            inserted++;
+                        } else {
+                            skipped++;
+                        }
+                    }
+                    db.setTransactionSuccessful();
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "batch insert failed", e);
+                    return errorJson("insert_failed");
+                } finally {
+                    db.endTransaction();
+                }
+            }
+            final JSONObject json = new JSONObject();
+            try {
+                json.put("inserted", inserted);
+                json.put("skipped", skipped);
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+
+        private long insertEventLocked(SQLiteDatabase db, JSONObject event) {
+            final long now = System.currentTimeMillis();
+            final long observedAt = event.optLong("observed_at", now);
+            final android.content.ContentValues values =
+                    new android.content.ContentValues();
+            values.put("source_type", event.optString("source_type", "").trim());
+            values.put("source_app", event.optString("source_app", ""));
+            values.put("source_record_id", event.optString("source_record_id", ""));
+            values.put("source_uid", Binder.getCallingUid());
+            values.put("observed_at", observedAt > 0 ? observedAt : now);
+            values.put("title", event.optString("title", ""));
+            values.put("text", event.optString("text", ""));
+            values.put("payload_json", event.optString("payload_json", "{}"));
+            values.put("created_at", now);
+            return db.insert("context_event", null, values);
+        }
+
+        @Override
+        public String queryEvents(String requestJson) {
+            enforceUseContextIndex();
+            JSONObject request;
+            try {
+                request = new JSONObject(requestJson == null || requestJson.isEmpty()
+                        ? "{}" : requestJson);
+            } catch (JSONException e) {
+                request = new JSONObject();
+            }
+            final String query = request.optString("query", "").trim();
+            final String sourceType = request.optString("source_type", "").trim();
+            final String sourceTypePrefix =
+                    request.optString("source_type_prefix", "").trim();
+            final int limit = Math.max(1,
+                    Math.min(request.optInt("limit", 20), MAX_LIMIT));
+
+            final StringBuilder where = new StringBuilder("e.deleted_at IS NULL");
+            final List<String> args = new ArrayList<>();
+            if (!sourceType.isEmpty()) {
+                where.append(" AND e.source_type = ?");
+                args.add(sourceType);
+            } else if (!sourceTypePrefix.isEmpty()) {
+                where.append(" AND e.source_type LIKE ?");
+                args.add(sourceTypePrefix.replace("%", "") + "%");
+            }
+
+            final List<JSONObject> events = new ArrayList<>();
+            synchronized (mDbLock) {
+                try {
+                    final SQLiteDatabase db = openLocked();
+                    if (!query.isEmpty()) {
+                        final String ftsQuery = query.replace('"', ' ').trim();
+                        final List<String> ftsArgs = new ArrayList<>(args);
+                        ftsArgs.add(0, ftsQuery);
+                        ftsArgs.add(Integer.toString(limit));
+                        try (Cursor cursor = db.rawQuery(
+                                "SELECT e.id, e.source_type, e.source_app, "
+                                        + "e.source_record_id, e.observed_at, e.title, "
+                                        + "e.text, e.payload_json "
+                                        + "FROM context_event_fts f "
+                                        + "JOIN context_event e ON e.id = f.rowid "
+                                        + "WHERE context_event_fts MATCH ? AND "
+                                        + where
+                                        + " ORDER BY e.observed_at DESC LIMIT ?",
+                                ftsArgs.toArray(new String[0]))) {
+                            readEventsLocked(cursor, events);
+                        } catch (RuntimeException e) {
+                            // Malformed FTS query: fall through to the latest scan.
+                            events.clear();
+                            latestLocked(db, where.toString(), args, limit, events);
+                        }
+                    }
+                    if (query.isEmpty()) {
+                        latestLocked(db, where.toString(), args, limit, events);
+                    }
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "query failed", e);
+                    return errorJson("query_failed");
+                }
+            }
+            final JSONObject json = new JSONObject();
+            try {
+                final JSONArray array = new JSONArray();
+                for (JSONObject event : events) {
+                    array.put(event);
+                }
+                json.put("events", array);
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+
+        @Override
+        public String tombstoneEvent(long eventId) {
+            enforceUseContextIndex();
+            if (eventId <= 0) {
+                return errorJson("invalid_event_id");
+            }
+            final long now = System.currentTimeMillis();
+            final int updated;
+            synchronized (mDbLock) {
+                try {
+                    final SQLiteDatabase db = openLocked();
+                    final android.content.ContentValues values =
+                            new android.content.ContentValues();
+                    values.put("deleted_at", now);
+                    updated = db.update("context_event", values, "id = ?",
+                            new String[]{Long.toString(eventId)});
+                    // Tombstoned content must stop being retrievable from search.
+                    db.execSQL("DELETE FROM context_event_fts WHERE rowid = ?",
+                            new Object[]{eventId});
+                } catch (RuntimeException e) {
+                    Slog.w(TAG, "tombstone failed", e);
+                    return errorJson("tombstone_failed");
+                }
+            }
+            final JSONObject json = new JSONObject();
+            try {
+                json.put("tombstoned", updated > 0);
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+
+        private void latestLocked(SQLiteDatabase db, String where, List<String> args,
+                int limit, List<JSONObject> events) {
+            final List<String> queryArgs = new ArrayList<>(args);
+            queryArgs.add(Integer.toString(limit));
+            try (Cursor cursor = db.rawQuery(
+                    "SELECT e.id, e.source_type, e.source_app, e.source_record_id, "
+                            + "e.observed_at, e.title, e.text, e.payload_json "
+                            + "FROM context_event e WHERE " + where
+                            + " ORDER BY e.observed_at DESC, e.id DESC LIMIT ?",
+                    queryArgs.toArray(new String[0]))) {
+                readEventsLocked(cursor, events);
+            }
+        }
+
+        private static void readEventsLocked(Cursor cursor, List<JSONObject> events) {
+            while (cursor.moveToNext()) {
+                final JSONObject event = new JSONObject();
+                try {
+                    event.put("id", cursor.getLong(0));
+                    event.put("source_type", cursor.getString(1));
+                    event.put("source_app", cursor.getString(2));
+                    event.put("source_record_id", cursor.getString(3));
+                    event.put("observed_at", cursor.getLong(4));
+                    event.put("title", cursor.getString(5));
+                    event.put("text", cursor.getString(6));
+                    event.put("payload_json", cursor.getString(7));
+                } catch (JSONException e) {
+                    continue;
+                }
+                events.add(event);
+            }
+        }
+
+        private SQLiteDatabase openLocked() {
+            if (mDb != null && mDb.isOpen()) {
+                return mDb;
+            }
+            final File dir = new File(Environment.getDataSystemDirectory(),
+                    OPENPHONE_SYSTEM_DIR);
+            if (!dir.exists() && !dir.mkdirs()) {
+                throw new IllegalStateException(
+                        "Unable to create OpenPhone system directory: " + dir);
+            }
+            final SQLiteDatabase db = SQLiteDatabase.openOrCreateDatabase(
+                    new File(dir, DB_FILE), null);
+            final int version = db.getVersion();
+            if (version < SCHEMA_VERSION) {
+                db.beginTransaction();
+                try {
+                    // Durable user data: migrations must be additive and stepwise,
+                    // never DROP TABLE.
+                    if (version < 1) {
+                        createSchemaLocked(db);
+                    }
+                    db.setVersion(SCHEMA_VERSION);
+                    db.setTransactionSuccessful();
+                } finally {
+                    db.endTransaction();
+                }
+            }
+            mDb = db;
+            return db;
+        }
+
+        private static void createSchemaLocked(SQLiteDatabase db) {
+            db.execSQL("CREATE TABLE IF NOT EXISTS context_event ("
+                    + "id INTEGER PRIMARY KEY AUTOINCREMENT,"
+                    + "source_type TEXT NOT NULL,"
+                    + "source_app TEXT NOT NULL,"
+                    + "source_record_id TEXT,"
+                    + "source_uid INTEGER NOT NULL DEFAULT 0,"
+                    + "observed_at INTEGER NOT NULL,"
+                    + "title TEXT,"
+                    + "text TEXT,"
+                    + "payload_json TEXT,"
+                    + "created_at INTEGER NOT NULL,"
+                    + "deleted_at INTEGER"
+                    + ")");
+            db.execSQL("CREATE VIRTUAL TABLE IF NOT EXISTS context_event_fts "
+                    + "USING fts4(title, text, content='context_event')");
+            db.execSQL("CREATE TRIGGER IF NOT EXISTS context_event_ai "
+                    + "AFTER INSERT ON context_event "
+                    + "BEGIN INSERT INTO context_event_fts(rowid, title, text) "
+                    + "VALUES (new.id, new.title, new.text); END");
+            db.execSQL("CREATE TRIGGER IF NOT EXISTS context_event_ad "
+                    + "AFTER DELETE ON context_event "
+                    + "BEGIN DELETE FROM context_event_fts WHERE rowid = old.id; END");
+            db.execSQL("CREATE TRIGGER IF NOT EXISTS context_event_au "
+                    + "AFTER UPDATE ON context_event "
+                    + "BEGIN DELETE FROM context_event_fts WHERE rowid = old.id; "
+                    + "INSERT INTO context_event_fts(rowid, title, text) "
+                    + "VALUES (new.id, new.title, new.text); END");
+            db.execSQL("CREATE INDEX IF NOT EXISTS context_event_source_idx "
+                    + "ON context_event(source_type, observed_at)");
+            db.execSQL("CREATE INDEX IF NOT EXISTS context_event_record_idx "
+                    + "ON context_event(source_record_id)");
+            db.execSQL("CREATE INDEX IF NOT EXISTS context_event_recent_idx "
+                    + "ON context_event(deleted_at, observed_at)");
+        }
+
+        private void enforceUseContextIndex() {
+            mContext.enforceCallingOrSelfPermission(
+                    PERMISSION_USE_CONTEXT_INDEX,
+                    "OpenPhone context index requires USE_CONTEXT_INDEX");
+        }
+
+        private static String errorJson(String error) {
+            final JSONObject json = new JSONObject();
+            try {
+                json.put("error", error);
+            } catch (JSONException e) {
+                throw new IllegalStateException(e);
+            }
+            return json.toString();
+        }
+    }
+}
