+@Module
+interface OpenPhoneSystemUIModule {
+    @Binds
+    @IntoMap
+    @StringKey(OpenPhoneAgentTile.TILE_SPEC)
+    fun bindOpenPhoneAgentTile(tile: OpenPhoneAgentTile): QSTileImpl<*>
+
+    companion object {
+        @Provides
+        @IntoMap
+        @StringKey(OpenPhoneAgentTile.TILE_SPEC)
+        fun provideOpenPhoneAgentTileConfig(uiEventLogger: QsEventLogger): QSTileConfig =
+            QSTileConfig(
+                tileSpec = TileSpec.create(OpenPhoneAgentTile.TILE_SPEC),
+                uiConfig =
+                    QSTileUIConfig.Resource(
+                        iconRes = R.drawable.ic_qs_openphone_agent,
+                        labelRes = R.string.quick_settings_openphone_agent_label,
+                    ),
+                instanceId = uiEventLogger.getNewInstanceId(),
+                category = TileCategory.UTILITIES,
+            )
+    }
+}
