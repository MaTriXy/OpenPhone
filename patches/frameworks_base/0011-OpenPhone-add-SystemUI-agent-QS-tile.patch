+/** SystemUI-owned OpenPhone agent control surface. */
+public class OpenPhoneAgentTile extends QSTileImpl<BooleanState> {
+    public static final String TILE_SPEC = "openphone_agent";
+
+    private static final String ASSISTANT_PACKAGE = "org.openphone.assistant";
+    private static final long REFRESH_INTERVAL_MS = 2000L;
+
+    private final OpenPhoneAgentManager mAgentManager;
+    private boolean mListening;
+
+    private final Runnable mRefreshWhileListening = new Runnable() {
+        @Override
+        public void run() {
+            if (!mListening) {
+                return;
+            }
+            refreshState();
+            mHandler.postDelayed(this, REFRESH_INTERVAL_MS);
+        }
+    };
+
+    @Inject
+    public OpenPhoneAgentTile(
+            QSHost host,
+            QsEventLogger uiEventLogger,
+            @Background Looper backgroundLooper,
+            @Main Handler mainHandler,
+            FalsingManager falsingManager,
+            MetricsLogger metricsLogger,
+            StatusBarStateController statusBarStateController,
+            ActivityStarter activityStarter,
+            QSLogger qsLogger
+    ) {
+        super(host, uiEventLogger, backgroundLooper, mainHandler, falsingManager, metricsLogger,
+                statusBarStateController, activityStarter, qsLogger);
+        mAgentManager = mContext.getSystemService(OpenPhoneAgentManager.class);
+    }
+
+    @Override
+    public BooleanState newTileState() {
+        return new BooleanState();
+    }
+
+    @Override
+    public void handleSetListening(boolean listening) {
+        super.handleSetListening(listening);
+        mListening = listening;
+        mHandler.removeCallbacks(mRefreshWhileListening);
+        if (listening) {
+            refreshState();
+            mHandler.postDelayed(mRefreshWhileListening, REFRESH_INTERVAL_MS);
+        }
+    }
+
+    @Override
+    protected void handleClick(@Nullable Expandable expandable) {
+        final String activeTaskId = firstActiveTaskId();
+        if (activeTaskId != null) {
+            mAgentManager.stopTask(activeTaskId, "{\"reason\":\"systemui_qs_tile\"}");
+            refreshState();
+            return;
+        }
+        mActivityStarter.postStartActivityDismissingKeyguard(getLongClickIntent(), 0);
+    }
+
+    @Override
+    public Intent getLongClickIntent() {
+        final Intent launchIntent = mContext.getPackageManager()
+                .getLaunchIntentForPackage(ASSISTANT_PACKAGE);
+        if (launchIntent != null) {
+            return launchIntent;
+        }
+        return new Intent(Intent.ACTION_MAIN).setPackage(ASSISTANT_PACKAGE);
+    }
+
+    @Override
+    public CharSequence getTileLabel() {
+        return mContext.getString(R.string.quick_settings_openphone_agent_label);
+    }
+
+    @Override
+    protected void handleUpdateState(BooleanState state, Object arg) {
+        final AgentStatus status = readAgentStatus();
+        state.value = status.activeTasks > 0;
+        state.state = status.available
+                ? (state.value ? Tile.STATE_ACTIVE : Tile.STATE_INACTIVE)
+                : Tile.STATE_UNAVAILABLE;
+        state.label = getTileLabel();
+        state.secondaryLabel = status.secondaryLabel;
+        state.icon = maybeLoadResourceIcon(R.drawable.ic_qs_openphone_agent);
+        state.expandedAccessibilityClassName = Switch.class.getName();
+        state.contentDescription = state.label + " - " + state.secondaryLabel;
+    }
+
+    @Override
+    public int getMetricsCategory() {
+        return MetricsEvent.QS_PANEL;
+    }
+
+    private AgentStatus readAgentStatus() {
+        if (mAgentManager == null) {
+            return AgentStatus.unavailable(
+                    mContext.getString(R.string.quick_settings_openphone_agent_unavailable));
+        }
+        try {
+            final JSONObject status = new JSONObject(mAgentManager.getServiceStatus());
+            final int activeTasks = status.optInt("active_tasks", 0);
+            final String secondaryLabel = activeTasks > 0
+                    ? mContext.getString(R.string.quick_settings_openphone_agent_active)
+                    : mContext.getString(R.string.quick_settings_openphone_agent_inactive);
+            return new AgentStatus(true, activeTasks, secondaryLabel);
+        } catch (JSONException | RuntimeException e) {
+            return AgentStatus.unavailable(
+                    mContext.getString(R.string.quick_settings_openphone_agent_unavailable));
+        }
+    }
+
+    @Nullable
+    private String firstActiveTaskId() {
+        if (mAgentManager == null) {
+            return null;
+        }
+        try {
+            final JSONObject status = new JSONObject(mAgentManager.getServiceStatus());
+            final JSONArray activeTaskIds = status.optJSONArray("active_task_ids");
+            if (activeTaskIds == null || activeTaskIds.length() == 0) {
+                return null;
+            }
+            return activeTaskIds.optString(0, null);
+        } catch (JSONException | RuntimeException e) {
+            return null;
+        }
+    }
+
+    private static final class AgentStatus {
+        final boolean available;
+        final int activeTasks;
+        final String secondaryLabel;
+
+        AgentStatus(boolean available, int activeTasks, String secondaryLabel) {
+            this.available = available;
+            this.activeTasks = activeTasks;
+            this.secondaryLabel = secondaryLabel;
+        }
+
+        static AgentStatus unavailable(String secondaryLabel) {
+            return new AgentStatus(false, 0, secondaryLabel);
+        }
+    }
+}
