From 97a2625ad083c63edd5f48594501db1903af5dd8 Mon Sep 17 00:00:00 2001
From: OpenPhone <dev@openphone.local>
Date: Tue, 16 Jun 2026 04:00:04 +0000
Subject: [PATCH] OpenPhone: finish volume hold voice capture on release

Change-Id: I2acc45e76c51770bb05550cbb41d838785ae196a
---
 .../server/policy/PhoneWindowManager.java     | 23 +++++++++++++++++++
 1 file changed, 23 insertions(+)

diff --git a/services/core/java/com/android/server/policy/PhoneWindowManager.java b/services/core/java/com/android/server/policy/PhoneWindowManager.java
index 38e64a96b016..0fd828253231 100644
--- a/services/core/java/com/android/server/policy/PhoneWindowManager.java
+++ b/services/core/java/com/android/server/policy/PhoneWindowManager.java
@@ -684,6 +684,7 @@ public class PhoneWindowManager implements WindowManagerPolicy {
     private boolean mOpenPhoneVolumeUpPressed;
     private boolean mOpenPhoneVolumeDownPressed;
     private boolean mOpenPhoneVolumeChordTriggered;
+    private boolean mOpenPhoneVolumeChordReleaseSent;
     private long mOpenPhoneLastVolumeUpDownTime;
     private long mOpenPhoneLastVolumeDownDownTime;
     private long mOpenPhoneLastVolumeChordTriggerTime;
@@ -4428,6 +4429,7 @@ public class PhoneWindowManager implements WindowManagerPolicy {
                     && isOpenPhoneVolumeChord(now)) {
                 mOpenPhoneVolumeChordTriggered = true;
                 mOpenPhoneLastVolumeChordTriggerTime = now;
+                mOpenPhoneVolumeChordReleaseSent = false;
                 clearOpenPhonePendingVolumeEvent();
                 launchOpenPhoneVolumeChordAction();
             }
@@ -4440,8 +4442,13 @@ public class PhoneWindowManager implements WindowManagerPolicy {
         } else {
             mOpenPhoneVolumeDownPressed = false;
         }
+        if (chordTriggered && !mOpenPhoneVolumeChordReleaseSent) {
+            mOpenPhoneVolumeChordReleaseSent = true;
+            finishOpenPhoneVolumeChordAction();
+        }
         if (!mOpenPhoneVolumeUpPressed && !mOpenPhoneVolumeDownPressed) {
             mOpenPhoneVolumeChordTriggered = false;
+            mOpenPhoneVolumeChordReleaseSent = false;
         }
         if (!chordTriggered && !event.isCanceled()
                 && mOpenPhonePendingVolumeDownEvent != null
@@ -4476,6 +4483,7 @@ public class PhoneWindowManager implements WindowManagerPolicy {
                 | Intent.FLAG_ACTIVITY_SINGLE_TOP
                 | Intent.FLAG_ACTIVITY_NO_ANIMATION);
         intent.putExtra("org.openphone.assistant.extra.TOGGLE_AGENT", true);
+        intent.putExtra("org.openphone.assistant.extra.HOLD_TO_RECORD", true);
         try {
             startActivityAsUser(intent, UserHandle.CURRENT_OR_SELF);
         } catch (RuntimeException e) {
@@ -4483,6 +4491,21 @@ public class PhoneWindowManager implements WindowManagerPolicy {
         }
     }
 
+    private void finishOpenPhoneVolumeChordAction() {
+        final Intent intent = new Intent();
+        intent.setComponent(new ComponentName("org.openphone.assistant",
+                "org.openphone.assistant.AgentControlActivity"));
+        intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK
+                | Intent.FLAG_ACTIVITY_SINGLE_TOP
+                | Intent.FLAG_ACTIVITY_NO_ANIMATION);
+        intent.putExtra("org.openphone.assistant.extra.FINISH_VOICE_CAPTURE", true);
+        try {
+            startActivityAsUser(intent, UserHandle.CURRENT_OR_SELF);
+        } catch (RuntimeException e) {
+            Slog.w(TAG, "Unable to finish OpenPhone volume chord action", e);
+        }
+    }
+
     private void replaceOpenPhonePendingVolumeEvent(KeyEvent event) {
         clearOpenPhonePendingVolumeEvent();
         mOpenPhonePendingVolumeDownEvent = KeyEvent.obtain(event);
-- 
2.43.0

