{
  "version": 1,
  "default_decision": "inherit",
  "package_overrides": [
    {
      "package": "com.android.permissioncontroller",
      "match": "exact",
      "capabilities": ["input.perform"],
      "decision": "explicit_confirm",
      "reason": "permission grants can expose private device data or accounts"
    },
    {
      "package": "com.android.settings",
      "match": "exact",
      "capabilities": ["input.perform", "clipboard.read", "clipboard.write"],
      "decision": "confirm",
      "reason": "settings screens can change device, account, security, or network state"
    },
    {
      "package": "com.google.android.vending",
      "match": "exact",
      "capabilities": ["input.perform", "share.content"],
      "decision": "explicit_confirm",
      "reason": "app marketplace flows can install apps or initiate purchases"
    },
    {
      "package": "com.google.android.gms",
      "match": "prefix",
      "capabilities": ["input.perform", "clipboard.read", "clipboard.write"],
      "decision": "explicit_confirm",
      "reason": "Google account and payment surfaces require explicit user approval"
    },
    {
      "package": "com.android.settings.password",
      "match": "prefix",
      "capabilities": ["input.perform", "screen.capture", "clipboard.read", "clipboard.write"],
      "decision": "deny",
      "reason": "lock credential and password surfaces are blocked for v1"
    }
  ]
}
