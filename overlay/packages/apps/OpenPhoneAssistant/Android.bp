package {
    default_applicable_licenses: ["OpenPhoneAssistant_license"],
}

license {
    name: "OpenPhoneAssistant_license",
    visibility: [":__subpackages__"],
    license_kinds: [
        "legacy_restricted",
    ],
    license_text: [
        "LICENSE",
    ],
}

android_app {
    name: "OpenPhoneAssistant",
    srcs: [
        "src/**/*.aidl",
        "src/**/*.java",
        "src/**/*.kt",
    ],
    resource_dirs: ["res"],
    manifest: "AndroidManifest.xml",
    static_libs: [
        "openphone_androidx_activity",
        "openphone_androidx_activity_compose",
        "openphone_androidx_activity_ktx",
        "openphone_androidx_annotation",
        "openphone_androidx_annotation_experimental",
        "openphone_androidx_arch_core_common",
        "openphone_androidx_arch_core_runtime",
        "openphone_androidx_collection",
        "openphone_androidx_collection_jvm",
        "openphone_androidx_compose_animation_android",
        "openphone_androidx_compose_animation_core_android",
        "openphone_androidx_compose_animation_graphics",
        "openphone_androidx_compose_animation_tooling_internal",
        "openphone_androidx_compose_foundation_android",
        "openphone_androidx_compose_foundation_layout_android",
        "openphone_androidx_compose_material",
        "openphone_androidx_compose_material3_android",
        "openphone_androidx_compose_material3_window_size_class",
        "openphone_androidx_compose_material_icons_core",
        "openphone_androidx_compose_material_ripple_android",
        "openphone_androidx_compose_runtime_android",
        "openphone_androidx_compose_runtime_saveable_android",
        "openphone_androidx_compose_ui_android",
        "openphone_androidx_compose_ui_geometry",
        "openphone_androidx_compose_ui_geometry_android",
        "openphone_androidx_compose_ui_graphics_android",
        "openphone_androidx_compose_ui_text_android",
        "openphone_androidx_compose_ui_tooling_preview_android",
        "openphone_androidx_compose_ui_unit_android",
        "openphone_androidx_compose_ui_util_android",
        "openphone_androidx_concurrent_futures",
        "openphone_androidx_core",
        "openphone_androidx_core_ktx",
        "openphone_androidx_customview_poolingcontainer",
        "openphone_androidx_emoji2",
        "openphone_androidx_interpolator",
        "openphone_androidx_lifecycle_common",
        "openphone_androidx_lifecycle_common_java8",
        "openphone_androidx_lifecycle_livedata_core",
        "openphone_androidx_lifecycle_process",
        "openphone_androidx_lifecycle_runtime",
        "openphone_androidx_lifecycle_runtime_compose",
        "openphone_androidx_lifecycle_runtime_ktx",
        "openphone_androidx_lifecycle_viewmodel",
        "openphone_androidx_lifecycle_viewmodel_compose",
        "openphone_androidx_lifecycle_viewmodel_ktx",
        "openphone_androidx_lifecycle_viewmodel_savedstate",
        "openphone_androidx_profileinstaller",
        "openphone_androidx_savedstate",
        "openphone_androidx_startup_runtime",
        "openphone_androidx_tracing",
        "openphone_androidx_versionedparcelable",
        "openphone_guava_listenablefuture",
        "openphone_jetbrains_annotations",
        "openphone_kotlin_stdlib",
        "openphone_kotlin_stdlib_common",
        "openphone_kotlin_stdlib_jdk7",
        "openphone_kotlin_stdlib_jdk8",
        "openphone_kotlinx_coroutines_android",
        "openphone_kotlinx_coroutines_core",
    ],
    kotlin_plugins: ["kotlin-compose-compiler-plugin"],
    kotlincflags: [
        "-P plugin:androidx.compose.compiler.plugins.kotlin:suppressKotlinVersionCompatibilityCheck=1.9.22",
    ],
    platform_apis: true,
    certificate: "platform",
    privileged: true,
    system_ext_specific: true,
}

