{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openphone.example/contracts/app-policy.schema.json",
  "title": "OpenPhone App Capability Policy",
  "type": "object",
  "required": ["version", "default_decision", "package_overrides"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "default_decision": {
      "type": "string",
      "enum": ["inherit", "allow", "confirm", "explicit_confirm", "deny"]
    },
    "package_overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["package", "match", "capabilities", "decision", "reason"],
        "additionalProperties": false,
        "properties": {
          "package": {
            "type": "string",
            "minLength": 1
          },
          "match": {
            "type": "string",
            "enum": ["exact", "prefix"]
          },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "decision": {
            "type": "string",
            "enum": ["allow", "confirm", "explicit_confirm", "deny"]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
