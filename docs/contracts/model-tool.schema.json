{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openphone.dev/schemas/model-tool.schema.json",
  "title": "OpenPhone Model Tool Registry",
  "type": "object",
  "required": ["version", "tools"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "capability", "kind", "requires_reason"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "capability": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "enum": ["observe", "action", "control"]
          },
          "requires_reason": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
