{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openphone.example/contracts/agent-eval-report.schema.json",
  "title": "OpenPhone Agent Eval Report",
  "type": "object",
  "required": [
    "schema",
    "eval_id",
    "goal",
    "device",
    "build",
    "model",
    "result",
    "evidence"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "openphone.agent_eval_report.v1"
    },
    "eval_id": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "device": {
      "type": "object",
      "required": ["codename", "sku"],
      "additionalProperties": false,
      "properties": {
        "codename": {
          "type": "string",
          "minLength": 1
        },
        "sku": {
          "type": "string"
        },
        "serial_redacted": {
          "type": "boolean"
        },
        "slot": {
          "type": "string"
        }
      }
    },
    "build": {
      "type": "object",
      "required": ["openphone_version", "assistant_version_code", "assistant_version_name"],
      "additionalProperties": false,
      "properties": {
        "openphone_version": {
          "type": "string",
          "minLength": 1
        },
        "assistant_version_code": {
          "type": "integer",
          "minimum": 1
        },
        "assistant_version_name": {
          "type": "string",
          "minLength": 1
        },
        "ota_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "git_commit": {
          "type": "string"
        }
      }
    },
    "model": {
      "type": "object",
      "required": ["provider", "name", "transport", "cloud"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "transport": {
          "type": "string",
          "enum": ["local", "direct_provider_dev", "openphone_broker"]
        },
        "cloud": {
          "type": "boolean"
        }
      }
    },
    "result": {
      "type": "object",
      "required": ["status", "summary"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "blocked", "needs_review"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "failure_reason": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["trajectory", "audit"],
      "additionalProperties": false,
      "properties": {
        "trajectory": {
          "type": "string",
          "minLength": 1
        },
        "audit": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
